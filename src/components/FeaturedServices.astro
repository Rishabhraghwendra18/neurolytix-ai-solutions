---

---

<section
  id="consulting-packages"
  class="relative py-24 bg-[#0F172A] overflow-hidden"
>
  <!-- Subtle radial glow behind the center of the grid -->
  <div
    class="absolute inset-0 flex place-content-center items-center pointer-events-none"
  >
    <div
      class="w-[300px] h-[300px] md:w-[600px] md:h-[600px] bg-[#818CF8] rounded-full blur-[100px] md:blur-[120px] opacity-10"
    >
    </div>
  </div>

  <div class="relative max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 z-10">
    <!-- Section Header -->
    <div class="text-center mb-12">
      <h2 class="font-inter font-bold text-3xl md:text-4xl text-[#F8FAFC] mb-4">
        Specialized Consulting Packages
      </h2>
      <p class="font-plus-jakarta-sans text-lg text-white/80 max-w-2xl mx-auto">
        Accelerate your digital transformation with our transparent, high-ROI
        service tiers.
      </p>
    </div>

    <!-- Content & Grid Layout -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      <!-- Card 1: AI Consultations -->
      <div
        class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl p-8 flex flex-col transition-all duration-300 hover:-translate-y-2 hover:border-[#38BDF8]/50 hover:shadow-[0_0_20px_rgba(56,189,248,0.2)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-10 h-10 text-[#38BDF8] mb-6"
        >
          <path
            d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"
          ></path>
          <path
            d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"
          ></path>
          <path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"></path>
          <path d="M17.599 6.5a3 3 0 0 0 .399-1.375"></path>
          <path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"></path>
          <path d="M3.477 10.896a4 4 0 0 1 .585-.396"></path>
          <path d="M19.938 10.5a4 4 0 0 1 .585.396"></path>
          <path d="M6 18a4 4 0 0 1-1.967-.516"></path>
          <path d="M19.967 17.484A4 4 0 0 1 18 18"></path>
        </svg>
        <h3 class="font-inter font-bold text-2xl text-[#F8FAFC] mb-2">
          AI Consultations
        </h3>
        <p class="font-inter font-bold text-3xl text-[#F8FAFC] mb-8">₹999</p>

        <ul class="space-y-4 mb-8 font-plus-jakarta-sans text-white/80">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Custom AI integration and implementation roadmap</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Identify high-ROI AI automation use cases</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Technical feasibility audit for your product</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Practical strategies to leverage Generative AI</span>
          </li>
        </ul>

        <a
          href="/checkout?plan=ai-consultation"
          class="mt-auto w-full inline-flex justify-center items-center px-6 py-3 rounded-lg border border-[#38BDF8] text-[#38BDF8] font-inter font-semibold transition-colors hover:bg-[#38BDF8]/10"
        >
          Book Now
        </a>
      </div>

      <!-- Card 2: Cloud Cost Optimizations (Most Popular) -->
      <div
        class="relative bg-white/5 backdrop-blur-lg border border-[#818CF8]/50 rounded-2xl p-8 flex flex-col transition-all duration-300 hover:-translate-y-2 hover:shadow-[0_0_20px_rgba(56,189,248,0.2)] md:-translate-y-4"
      >
        <!-- Top Badge -->
        <div
          class="absolute -top-4 left-1/2 -translate-x-1/2 bg-gradient-to-r from-[#38BDF8] to-[#818CF8] text-[#F8FAFC] text-sm font-bold px-4 py-1 rounded-full font-inter whitespace-nowrap shadow-lg"
        >
          High ROI
        </div>

        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-10 h-10 text-[#818CF8] mb-6"
        >
          <path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"></path>
        </svg>
        <h3 class="font-inter font-bold text-2xl text-[#F8FAFC] mb-2">
          Cloud Cost Optimizations
        </h3>
        <p class="font-inter font-bold text-3xl text-[#F8FAFC] mb-8">₹3,999</p>

        <ul class="space-y-4 mb-8 font-plus-jakarta-sans text-white/80">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Reduce monthly AWS bills by 20%</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Eliminate idle resources and hidden costs</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Architect scalable, cost-efficient cloud infrastructure</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Optimize performance while lowering resource usage</span>
          </li>
        </ul>

        <a
          href="/checkout?plan=cloud-optimization"
          class="mt-auto w-full inline-flex justify-center items-center px-6 py-3 rounded-lg bg-gradient-to-r from-[#38BDF8] to-[#818CF8] text-[#F8FAFC] font-inter font-semibold transition-opacity hover:opacity-90 shadow-lg shadow-[#38BDF8]/20"
        >
          Book Now
        </a>
      </div>

      <!-- Card 3: Cybersecurity & DevSecOps -->
      <div
        class="bg-white/5 backdrop-blur-lg border border-white/10 rounded-2xl p-8 flex flex-col transition-all duration-300 hover:-translate-y-2 hover:border-[#38BDF8]/50 hover:shadow-[0_0_20px_rgba(56,189,248,0.2)]"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="24"
          height="24"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          class="w-10 h-10 text-[#38BDF8] mb-6"
        >
          <path
            d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2-1 4-2 7-2 2.5 0 4.5 1 6.5 2a1 1 0 0 1 1 1v7z"
          ></path>
        </svg>
        <h3 class="font-inter font-bold text-2xl text-[#F8FAFC] mb-2">
          Cybersecurity & DevSecOps
        </h3>
        <p class="font-inter font-bold text-3xl text-[#F8FAFC] mb-8">₹9,999</p>

        <ul class="space-y-4 mb-8 font-plus-jakarta-sans text-white/80">
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Build secure, automated CI/CD deployment pipelines</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Implement zero-trust security for your apps</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Proactive vulnerability scanning and compliance checks</span>
          </li>
          <li class="flex items-start gap-3">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="24"
              height="24"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              class="w-5 h-5 text-[#38BDF8] shrink-0 mt-0.5"
              ><path d="M20 6 9 17l-5-5"></path></svg
            >
            <span>Secure your architecture against modern threats</span>
          </li>
        </ul>

        <a
          href="/checkout?plan=cybersecurity"
          class="mt-auto w-full inline-flex justify-center items-center px-6 py-3 rounded-lg border border-[#38BDF8] text-[#38BDF8] font-inter font-semibold transition-colors hover:bg-[#38BDF8]/10"
        >
          Book Now
        </a>
      </div>
    </div>
  </div>
</section>
