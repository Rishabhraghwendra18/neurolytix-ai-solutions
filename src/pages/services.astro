---
import Layout from '../layouts/Layout.astro';

const services = [
  {
    title: "AI Consultations",
    price: "₹999",
    iconColor: "text-[#38BDF8]",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M12 5a3 3 0 1 0-5.997.125 4 4 0 0 0-2.526 5.77 4 4 0 0 0 .556 6.588A4 4 0 1 0 12 18Z"/><path d="M12 5a3 3 0 1 1 5.997.125 4 4 0 0 1 2.526 5.77 4 4 0 0 1-.556 6.588A4 4 0 1 1 12 18Z"/><path d="M15 13a4.5 4.5 0 0 1-3-4 4.5 4.5 0 0 1-3 4"/><path d="M17.599 6.5a3 3 0 0 0 .399-1.375"/><path d="M6.003 5.125A3 3 0 0 0 6.401 6.5"/><path d="M3.477 10.896a4 4 0 0 1 .585-.396"/><path d="M19.938 10.5a4 4 0 0 1 .585.396"/><path d="M6 18a4 4 0 0 1-1.967-.516"/><path d="M19.967 17.484A4 4 0 0 1 18 18"/></svg>`,
    features: [
      "Custom AI integration and implementation roadmap",
      "Identify high-ROI AI automation use cases",
      "Technical feasibility audit for your product",
      "Practical strategies to leverage Generative AI"
    ],
    ctaLink: "/checkout?plan=ai-consultation",
    highlight: false
  },
  {
    title: "Cloud Cost Optimizations",
    price: "₹3,999",
    iconColor: "text-[#818CF8]",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M17.5 19H9a7 7 0 1 1 6.71-9h1.79a4.5 4.5 0 1 1 0 9Z"/></svg>`,
    features: [
      "Reduce monthly AWS bills by 20%",
      "Eliminate idle resources and hidden costs",
      "Architect scalable, cost-efficient cloud infrastructure",
      "Optimize performance while lowering resource usage"
    ],
    ctaLink: "/checkout?plan=cloud-optimization",
    highlight: true
  },
  {
    title: "Cybersecurity & DevSecOps",
    price: "₹9,999",
    iconColor: "text-[#38BDF8]",
    icon: `<svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"><path d="M20 13c0 5-3.5 7.5-7.66 8.95a1 1 0 0 1-.67-.01C7.5 20.5 4 18 4 13V6a1 1 0 0 1 1-1c2 0 4.5-1.2 6.24-2.72a1.17 1.17 0 0 1 1.52 0C14.51 3.81 17 5 19 5a1 1 0 0 1 1 1z"/></svg>`,
    features: [
      "Build secure, automated CI/CD deployment pipelines",
      "Implement zero-trust security for your apps",
      "Proactive vulnerability scanning and compliance checks",
      "Secure your architecture against modern threats"
    ],
    ctaLink: "/checkout?plan=cybersecurity",
    highlight: false
  }
];
---

<Layout title="Services & Pricing | Neurolytix AI Solutions">
  <section class="relative min-h-screen py-24 md:py-32 overflow-hidden bg-[#0F172A]">
    <!-- Background Design Elements -->
    <div class="absolute inset-0 bg-mesh opacity-40 mix-blend-screen pointer-events-none"></div>
    <div class="absolute top-0 right-0 -mr-32 -mt-32 w-[500px] h-[500px] rounded-full bg-[#38BDF8]/10 blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-0 left-0 -ml-32 -mb-32 w-[500px] h-[500px] rounded-full bg-[#818CF8]/10 blur-[100px] pointer-events-none"></div>

    <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 relative z-10">
      
      <!-- Page Header -->
      <div class="text-center max-w-3xl mx-auto mb-20 fade-in-up">
        <h1 class="text-4xl md:text-5xl lg:text-6xl font-extrabold mb-8 tracking-tighter leading-tight font-heading">
          <span class="text-[#F8FAFC]">Architecting Intelligence.</span><br />
          <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#38BDF8] to-[#818CF8]">Scaling Performance.</span>
        </h1>
        <p class="text-lg md:text-xl text-[#F8FAFC]/80 leading-relaxed font-body">
          Choose a specialized consultation package to accelerate your digital transformation. Transparent pricing, cutting-edge execution.
        </p>
      </div>

      <!-- Pricing Packages Grid -->
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-8 items-stretch pt-6">
        {services.map((service, index) => (
          <div class={`glass relative p-8 md:p-10 rounded-3xl flex flex-col h-full bg-white/5 backdrop-blur-xl transition-all duration-300 hover:-translate-y-2 group ${
            service.highlight 
              ? 'border border-[#818CF8]/50 shadow-[0_0_40px_rgba(129,140,248,0.15)] ring-1 ring-[#818CF8]/20 bg-gradient-to-b from-[#818CF8]/5 to-transparent z-10 lg:scale-105' 
              : 'border border-white/10 hover:border-[#38BDF8]/30 hover:shadow-[0_0_30px_rgba(56,189,248,0.1)]'
          }`}>
            
            {service.highlight && (
              <div class="absolute -top-4 left-1/2 -translate-x-1/2">
                <span class="bg-gradient-to-r from-[#38BDF8] to-[#818CF8] text-white text-xs font-bold px-5 py-2 rounded-full shadow-lg whitespace-nowrap uppercase tracking-wider">
                  High ROI Focus
                </span>
              </div>
            )}
            
            <div class="mb-8">
              <div class={`inline-flex items-center justify-center w-16 h-16 rounded-2xl bg-white/5 border border-white/10 mb-6 shadow-inner ${service.iconColor}`} set:html={service.icon} />
              <h3 class="text-2xl font-bold font-heading text-[#F8FAFC] mb-4">{service.title}</h3>
              <div class="flex items-baseline">
                <span class="text-5xl font-extrabold text-transparent bg-clip-text bg-gradient-to-r from-[#F8FAFC] to-[#F8FAFC]/70">{service.price}</span>
              </div>
            </div>

            <div class="flex-grow">
              <ul class="space-y-5 mb-10">
                {service.features.map(feature => (
                  <li class="flex items-start gap-4 text-[#F8FAFC]/85 text-[15px] leading-relaxed">
                    <div class="shrink-0 mt-1 bg-[#38BDF8]/10 p-1 rounded-full text-[#38BDF8]">
                      <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="20 6 9 17 4 12"/></svg>
                    </div>
                    <span>{feature}</span>
                  </li>
                ))}
              </ul>
            </div>

            <a href={service.ctaLink} class={`block w-full text-center py-4 px-6 rounded-xl font-bold transition-all duration-300 shadow-xl ${
              service.highlight 
                ? 'bg-gradient-to-r from-[#38BDF8] to-[#818CF8] text-white hover:opacity-90 hover:shadow-[0_0_20px_rgba(56,189,248,0.4)]' 
                : 'bg-white/10 text-white hover:bg-white/20 border border-white/10 hover:border-white/20'
            }`}>
              Book Now
            </a>
          </div>
        ))}
      </div>
      
    </div>
  </section>
</Layout>

<style>
  .fade-in-up {
    animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
  }
  
  @keyframes fadeInUp {
    from {
      opacity: 0;
      transform: translateY(20px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
